+# AccessRevamp — Netlify build and function configuration
+# Copy these values into Netlify Site configuration > Environment variables.
+# Never commit real secrets.
+
+# Build-time public values
+# Netlify also provides URL automatically after the first site is created.
+PUBLIC_SITE_URL=https://YOUR-SITE-NAME.netlify.app
+PUBLIC_CONTACT_EMAIL=REPLACE_WITH_REAL_MONITORED_EMAIL
+PUBLIC_BUSINESS_LEGAL_NAME=AccessRevamp
+
+# Runtime canonical origin. Use the same production URL as PUBLIC_SITE_URL.
+SITE_URL=https://YOUR-SITE-NAME.netlify.app
+
+# Dedicated AccessRevamp Supabase project only — do not reuse an unrelated database.
+SUPABASE_URL=https://YOUR-ACCESSREVAMP-PROJECT.supabase.co
+SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
+SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME
+
+# Stripe sandbox first. Prefer a restricted key with only the permissions needed
+# to create/retrieve Checkout Sessions; never expose it to browser code.
+STRIPE_API_KEY=rk_test_REPLACE_ME
+STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
+# Current AccessRevamp sandbox catalog prices. Replace with matching live-mode
+# price IDs only after the live products are created and verified.
+STRIPE_HOMEPAGE_REVEAL_PRICE_ID=price_1TuGoNLzyGRcyGQJRjtGsiMV
+STRIPE_COMPLETE_REVAMP_PRICE_ID=price_1TuGoTLzyGRcyGQJfdkqoE3f
+STRIPE_AUTOMATIC_TAX=false
+
+# Generate each value independently with at least 32 random characters.
+REQUEST_HASH_SECRET=replace-with-at-least-32-random-characters
+UNSUBSCRIBE_SECRET=replace-with-at-least-32-random-characters
+AUTOMATION_TOKEN=replace-with-at-least-32-random-characters
+
+# Comma-separated staff emails allowed to open /ops/ after authentication.
+ADMIN_EMAILS=owner@example.com
+
+# Outreach and controlled-delivery guardrails. A real sender identity, monitored
+# mailbox, valid postal address, and authenticated sending domain are required.
+# The Google Apps Script bridge has an independent enable switch.
+SENDER_FULL_NAME=
+BUSINESS_POSTAL_ADDRESS=
+ALLOW_COMMERCIAL_SEND=false
