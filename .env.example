# Public build variables
VITE_SITE_URL=https://your-server-capable-site.example
VITE_CONTACT_EMAIL=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_PAYMENT_MODE=test

# Supabase server variables — never prefix these with VITE_
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe server variables. Use separate restricted keys with the minimum permissions
# required by each function. Never reuse the refund key for checkout or webhook reads.
STRIPE_CHECKOUT_SECRET_KEY=
STRIPE_WEBHOOK_READ_SECRET_KEY=
STRIPE_REFUND_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_EXPECT_LIVEMODE=false
ACCESSREVAMP_LIVE_PAYMENT_APPROVED=false

# Catalog maintenance tooling only. This must remain a TEST key unless an explicitly
# reviewed live-catalog operation is being performed outside the application runtime.
STRIPE_SECRET_KEY=
STRIPE_HOMEPAGE_REVEAL_FULL_PRICE_ID=
STRIPE_COMPLETE_REVAMP_FULL_PRICE_ID=
STRIPE_CINEMATIC_FULL_PRICE_ID=
STRIPE_HOMEPAGE_TO_COMPLETE_PRICE_ID=
STRIPE_HOMEPAGE_TO_CINEMATIC_PRICE_ID=
STRIPE_COMPLETE_TO_CINEMATIC_PRICE_ID=

ACCESSREVAMP_SITE_URL=https://your-server-capable-site.example
CONTACT_RATE_LIMIT_SECRET=
ALLOWED_ORIGINS=https://your-server-capable-site.example

# Local AccessRevamp mailbox MCP. Keep every credential in an ignored local environment.
ACCESSREVAMP_GRAPH_TENANT_ID=
ACCESSREVAMP_GRAPH_CLIENT_ID=
ACCESSREVAMP_GRAPH_CERTIFICATE_PATH=
# Development-only alternative to a certificate. Do not commit a value.
ACCESSREVAMP_GRAPH_CLIENT_SECRET=
ACCESSREVAMP_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
ACCESSREVAMP_MAILBOX_DRAFT_WRITES_ENABLED=false
ACCESSREVAMP_MESSAGE_STATE_WRITES_ENABLED=false
ACCESSREVAMP_ICEMAIL_INVENTORY_SYNC_ENABLED=false
ACCESSREVAMP_MAILBOX_MAX_SEARCH_RESULTS=25
ACCESSREVAMP_MAILBOX_MAX_BODY_CHARACTERS=20000
ACCESSREVAMP_MAILBOX_OPERATOR_LABEL=accessrevamp-mailbox-mcp
ICEMAIL_API_BASE_URL=https://app.icemail.ai/api/v1
ICEMAIL_API_KEY=
