VITE_CONTACT_EMAIL=
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Browser-visible Stripe catalog. Keep sandbox values during test mode.
