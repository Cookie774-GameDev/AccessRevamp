# Copy these names into Netlify's environment variable UI.
# Never commit real secret values.

# Public browser configuration
VITE_SITE_URL=https://YOUR-SITE.netlify.app
VITE_CONTACT_EMAIL=
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_PAYMENT_MODE=test

# Server-only Supabase configuration
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Server-only Stripe configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_EXPECT_LIVEMODE=false
ACCESSREVAMP_LIVE_PAYMENT_APPROVED=false
STRIPE_HOMEPAGE_REVEAL_FULL_PRICE_ID=
STRIPE_COMPLETE_REVAMP_FULL_PRICE_ID=
STRIPE_CINEMATIC_FULL_PRICE_ID=
STRIPE_HOMEPAGE_TO_COMPLETE_PRICE_ID=
STRIPE_HOMEPAGE_TO_CINEMATIC_PRICE_ID=
STRIPE_COMPLETE_TO_CINEMATIC_PRICE_ID=

# Browser-write protection and rate limiting
ALLOWED_ORIGINS=https://YOUR-SITE.netlify.app
CONTACT_RATE_LIMIT_SECRET=

# Important production rule:
# bind the separately approved server-only live catalog, expected mode, and
# ACCESSREVAMP_LIVE_PAYMENT_APPROVED=true in one reviewed deployment change.
# Do not mix test and live records.
