# Copy these names into Netlify's environment variable UI.
# Never commit real secret values.

# Public browser configuration
VITE_SITE_URL=https://YOUR-SITE.netlify.app
VITE_CONTACT_EMAIL=
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Browser-visible Stripe catalog. Keep sandbox values during test mode.
VITE_STRIPE_HOMEPAGE_REVEAL_PRICE_ID=price_1TuGoNLzyGRcyGQJRjtGsiMV
VITE_STRIPE_QUICK_FIX_PRICE_ID=price_1TuGoTLzyGRcyGQJfdkqoE3f
VITE_STRIPE_HOMEPAGE_REVEAL_URL=https://book.stripe.com/test_dRmdRabhid0QfBfedagQE00
VITE_STRIPE_QUICK_FIX_URL=https://book.stripe.com/test_cNi00k99a1i81Kp6KIgQE01

# Server-only Supabase configuration
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Server-only Stripe configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_HOMEPAGE_REVEAL_PRICE_ID=price_1TuGoNLzyGRcyGQJRjtGsiMV
STRIPE_QUICK_FIX_PRICE_ID=price_1TuGoTLzyGRcyGQJfdkqoE3f

# Browser-write protection and rate limiting
ALLOWED_ORIGINS=https://YOUR-SITE.netlify.app
CONTACT_RATE_LIMIT_SECRET=

# Important production rule:
# replace every test-mode Stripe ID and test payment link with the matching
# live-mode value in the same deployment change. Do not mix test and live IDs.
